{
  "name": "dolibarr-mcp",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "MCP server for Dolibarr ERP REST API",
  "bin": "./build/index.js",
  "scripts": {
    "build": "tsc",
    "test": "npm run build && npm run test:unit",
